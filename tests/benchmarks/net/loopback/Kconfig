# This normally would be selected in the Kconfig of the driver, but since the
# benchmark provides its own fake Ethernet driver, we set the default here.
# We can't use the prj.conf file to enable it, because it is promptless.
configdefault NET_CHECKSUM_OFFLOAD_SUPPORTED
	default y

source "Kconfig.zephyr"
