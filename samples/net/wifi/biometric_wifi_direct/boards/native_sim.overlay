/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * Use the biometrics emulator so the demo runs on native_sim without
 * physical hardware.  The emulator pre-populates one enrolled template,
 * so the scan will succeed immediately.
 */

/ {
	aliases {
		fingerprint = &biometrics_emul;
	};

	biometrics_emul: biometrics-emul {
		compatible = "zephyr,biometrics-emul";
		status = "okay";
	};
};
