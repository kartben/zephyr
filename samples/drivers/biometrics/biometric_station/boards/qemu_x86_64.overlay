/ {
	aliases {
		//		biometrics = &biometrics_emul;
		biometrics = &dfrobot_ai10;
	};

	biometrics_emul: biometrics-emul {
		compatible = "zephyr,biometrics-emul";
		status = "okay";
	};
};

&uart1 {
	current-speed = <115200>;

	dfrobot_ai10: dfrobot_ai10 {
		compatible = "dfrobot,ai10";
		status = "okay";
	};
};
