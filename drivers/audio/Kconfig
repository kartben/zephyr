menuconfig AUDIO
	bool "Audio drivers"
	help
	  Enable support for Audio

if AUDIO
#
# Audio Codec options
#
menuconfig AUDIO_CODEC
	bool "Audio Codec Drivers"
	help
	  Enable Audio Codec Driver Configuration

if AUDIO_CODEC

config AUDIO_CODEC_INIT_PRIORITY
	int "Init priority"
	default 60
	help
	  Audio codec device driver initialization priority.

config AUDIO_CODEC_SHELL
	bool "Audio Codec shell"
	depends on SHELL
	help
	  Enable the Audio Codec shell with Audio Codec related commands.

module = AUDIO_CODEC
module-str = audio codec
source "subsys/logging/Kconfig.template.log_config"

# zephyr-keep-sorted-start
source "drivers/audio/Kconfig.aw88298"
source "drivers/audio/Kconfig.codec_dummy"
source "drivers/audio/Kconfig.cs43l22"
source "drivers/audio/Kconfig.da7212"
source "drivers/audio/Kconfig.max98091"
source "drivers/audio/Kconfig.pcm1681"
source "drivers/audio/Kconfig.sf32lb"
source "drivers/audio/Kconfig.tas6422dac"
source "drivers/audio/Kconfig.tlv320aic3110"
source "drivers/audio/Kconfig.tlv320dac"
source "drivers/audio/Kconfig.wm8904"
source "drivers/audio/Kconfig.wm8962"
# zephyr-keep-sorted-stop

endif # AUDIO_CODEC

menuconfig AUDIO_DMIC
	bool "Digital Microphone (Audio) Drivers"
	help
	  Enable Digital Microphone Driver Configuration

if AUDIO_DMIC

config AUDIO_DMIC_INIT_PRIORITY
	int "Init priority"
	default 80
	help
	  Audio Digital Microphone device driver initialization priority.

config AUDIO_DMIC_SHELL
	bool "Audio DMIC shell"
	depends on SHELL
	help
	  Enable the Audio DMIC shell with commands for reading audio data and
	  displaying a live VU meter from a digital microphone device.

if AUDIO_DMIC_SHELL

config DMIC_SHELL_BLOCK_DURATION_MS
	int "PCM block duration for shell buffer sizing (ms)"
	default 50
	range 1 1000
	help
	  Duration of each PCM block in milliseconds. Together with the maximum
	  sample rate, channel count, and PCM width options, this determines the
	  size of each block in the DMIC shell memory slab.

config DMIC_SHELL_MAX_SAMPLE_RATE
	int "Maximum sample rate for shell buffer sizing (Hz)"
	default 48000
	range 8000 192000
	help
	  Upper bound on sample rate used to size the DMIC shell memory slab.
	  Runtime configuration passed to the dmic read/vu commands must not
	  require a larger block than this allows.

config DMIC_SHELL_MAX_CHANNELS
	int "Maximum channel count for shell buffer sizing"
	default 2
	range 1 2
	help
	  Upper bound on channel count used to size the DMIC shell memory slab.

choice DMIC_SHELL_MAX_PCM_WIDTH
	prompt "Maximum PCM sample width for shell buffer sizing"
	default DMIC_SHELL_MAX_PCM_WIDTH_32
	help
	  Upper bound on PCM width in bits used to size the DMIC shell memory slab.

config DMIC_SHELL_MAX_PCM_WIDTH_16
	bool "16-bit"

config DMIC_SHELL_MAX_PCM_WIDTH_32
	bool "32-bit"

endchoice

config DMIC_SHELL_BLOCK_COUNT
	int "Number of blocks in the DMIC shell memory slab"
	default 4
	range 1 32
	help
	  Number of PCM blocks reserved in the slab (for pipelining / DMA).
	  Increasing this raises RAM use by one maximum-sized block per unit.

config DMIC_SHELL_MONO_PDM_RIGHT
	bool "Use the right PDM slot for mono shell capture"
	default y if BOARD_M5STICKC_PLUS
	help
	  Select the PDM left/right slot requested by the DMIC shell when
	  capturing a single PCM channel. Most boards use the left slot, but
	  some onboard PDM microphones are strapped to the right slot.

config DMIC_SHELL_READ_TIMEOUT_MS
	int "Timeout for dmic_read() in shell commands (ms)"
	default 2000
	range 100 60000

config DMIC_SHELL_VU_DEFAULT_DURATION_MS
	int "Default VU meter run duration (ms)"
	default 10000
	range 100 600000

config DMIC_SHELL_VU_MARGINS
	int "Terminal character margin for VU meter prefix and suffix"
	default 18
	range 4 256
	help
	  Characters reserved on each line so the VU bar fits between the fixed
	  prefix (e.g. "CH0 |") and suffix (level and clip indicator).

config DMIC_SHELL_VU_BAR_MIN
	int "Minimum VU meter bar width (characters)"
	default 4
	range 1 256

endif # AUDIO_DMIC_SHELL

module = AUDIO_DMIC
module-str = audio_dmic
source "subsys/logging/Kconfig.template.log_config"

# zephyr-keep-sorted-start
source "drivers/audio/Kconfig.dmic_ambiq_pdm"
source "drivers/audio/Kconfig.dmic_esp32"
source "drivers/audio/Kconfig.dmic_infineon"
source "drivers/audio/Kconfig.dmic_mcux"
source "drivers/audio/Kconfig.dmic_native_sim"
source "drivers/audio/Kconfig.dmic_nxp_micfil"
source "drivers/audio/Kconfig.dmic_pdm_nrfx"
source "drivers/audio/Kconfig.mpxxdtyy"
# zephyr-keep-sorted-stop

endif # AUDIO_DMIC

endif # AUDIO
