config BIOMETRICS_ID809
	bool "DFRobot ID809 Capacitive Fingerprint Sensor"
	default y
	depends on DT_HAS_DFROBOT_ID809_ENABLED || DT_HAS_DFROBOT_ID809_I2C_ENABLED
	select SERIAL if DT_HAS_DFROBOT_ID809_ENABLED
	select UART_INTERRUPT_DRIVEN if DT_HAS_DFROBOT_ID809_ENABLED
	select I2C if DT_HAS_DFROBOT_ID809_I2C_ENABLED
	help
	  Enable driver for the DFRobot ID809 capacitive fingerprint sensor
	  (SEN0348). Supports both UART (interrupt-driven) and I2C bus variants.

if BIOMETRICS_ID809

config ID809_TIMEOUT_MS
	int "Default operation timeout in milliseconds"
	default 10000
	help
	  Default timeout for fingerprint detection, enrollment, and matching
	  operations. Can be overridden at runtime via biometric_attr_set().

endif # BIOMETRICS_ID809
